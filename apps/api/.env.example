# ============================================================
# Proptech API — Environment Variables
# Copy to .env and fill in real values:  cp .env.example .env
# ============================================================

# ---- Server ----
NODE_ENV=development           # development | production | test
PORT=3001                      # API server port
API_PREFIX=api                 # Global route prefix (/api/...)

# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://proptech:CHANGE_ME@localhost:5432/proptech?schema=public"

# ---- JWT Authentication ----
JWT_ACCESS_SECRET=CHANGE_ME    # Access token secret (min 32 chars)
JWT_REFRESH_SECRET=CHANGE_ME   # Refresh token secret (min 32 chars)
JWT_ACCESS_EXPIRY=15m          # Access token TTL (15m, 1h, etc.)
JWT_REFRESH_EXPIRY=7d          # Refresh token TTL (7d, 30d, etc.)

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost

# ---- Swagger / API Docs ----
SWAGGER_ENABLED=true           # Set to false in production

# ---- Redis (future: caching, queues) ----
# REDIS_URL=redis://:CHANGE_ME@localhost:6379
