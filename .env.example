# ============================================================
# Proptech Platform — Root Environment Variables
# Used by docker-compose.yml — copy to .env
# ============================================================

# ---- PostgreSQL ----
POSTGRES_DB=proptech
POSTGRES_USER=proptech
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
REDIS_PORT=6379

# ---- JWT Secrets (CHANGE IN PRODUCTION!) ----
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost

# ---- Swagger ----
# SECURITY: MUST be 'false' in production — exposes all API endpoints
SWAGGER_ENABLED=false

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Proptech

# ---- Ports ----
API_PORT=3001
WEB_PORT=3000
NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443

# ---- pgAdmin (dev only) ----
PGADMIN_EMAIL=admin@proptech.sa
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
